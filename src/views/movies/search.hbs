<section id="search">
    <h1>Search</h1>
    <form action="/movies/search" method="get" class="form">
        <input type="text" class="search" name="search" placeholder="Title...">
        <input type="text" name="genre" class="genre" placeholder="Genre...">
        <input type="number" name="year" class="year" placeholder="Year...">
        <input type="submit" value="search">
    </form>
</section>

<section id="catalog">
    <div class="band">

        <!-- If there are posts for movie in the database display each of them -->
        {{#each movies}}
        <div class="flip flip-vertical">
            <div class="front">
                <img src="{{this.imageUrl}}" alt="{{this.title}}">
            </div>
            <div class="back">
                <h1>{{this.title}}</h1>
                <h2>Genre: {{this.genre}}</h2>
                <p>Description: {{this.description}}</p>
                <a href="/movies/{{this.id}}" class="details">Details</a>
            </div>
        </div>
        {{else}}
        <!-- If there are still no posts in the database display: -->
        <div class="no-posts">
            <p class="no-offer">There are no movie yet...</p>
        </div>
        {{/each}}
    </div>
</section>