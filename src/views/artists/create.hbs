<section id="create-cast">
    <div class="createCastSection">
        <div class="info-cast">
            <h2>"You're gonna need a bigger boat." — "Jaws," 1975.</h2>
        </div>

        <form method="post" class="createCastForm">
            <h2>Add Cast</h2>
            <ul class="noBullet">
                <li>
                    <label for="name">Name:</label>
                    <input type="text" class="inputFields" id="name" name="name" value="{{data.name}}"/>
                    {{> showErrors errors=errors.name}}
                </li>
                <li>
                    <label for="age">Age:</label>
                    <input type="number" class="inputFields" id="age" name="age" value="{{data.age}}" />
                    {{> showErrors errors=errors.age}}
                </li>
                <li>
                    <label for="born">Born:</label>
                    <input type="text" class="inputFields" id="born" name="born" value="{{data.born}}" />
                    {{> showErrors errors=errors.born}}
                </li>
                <li>
                    <label for="character">Name in Movie:</label>
                    <input type="text" class="inputFields" id="character" name="character" value="{{data.character}}"/>
                    {{> showErrors errors=errors.character}}
                </li>
                <li>
                    <label for="image">Cast Image:</label>
                    <input type="text" class="inputFields" id="image" name="imageUrl" value="{{data.imageUrl}}"/>
                    {{> showErrors errors=errors.imageUrl}}

                </li>
                <li id="center-btn">
                    <button id="create-btn">Add Artist</button>
                </li>
            </ul>
        </form>

    </div>
</section>