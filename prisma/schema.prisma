// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id          String   @id @default(cuid())
  title       String @unique
  category    String
  genre       String
  director    String
  year        Int
  imageUrl    String
  rating      Float
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creatorId   String?

  artists Artist[]
  creator User?     @relation(fields: [creatorId], references: [id])

  @@map("movies")
}

model Artist {
  id          String   @id @default(cuid())
  name        String
  age         Int
  born        String
  imageUrl    String
  character String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movies Movie[]

  @@map("artists")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String

  movies Movie[]

  @@map("users")
}
